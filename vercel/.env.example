# M-Pesa Callback Configuration
# Set these environment variables in Vercel dashboard under Project Settings > Environment Variables

MPESA_CALLBACK_URL=https://your-vercel-project.vercel.app/api/mpesa/callback
MPESA_CONSUMER_KEY=replace-with-mpesa-consumer-key
MPESA_CONSUMER_SECRET=replace-with-mpesa-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=replace-with-mpesa-passkey

# Paystack Webhook Configuration
PAYSTACK_WEBHOOK_SECRET=replace-with-paystack-webhook-secret
PAYSTACK_WEBHOOK_SERVER_URL=https://your-server.example.com
BETWISE_SERVER_URL=https://your-server.example.com
