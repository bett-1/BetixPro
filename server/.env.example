NODE_ENV=production
PORT=5000

# Core application URLs
VITE_API_BASE_URL=https://server.betixpro.com/api
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
CLIENT_URL=https://betixpro.com,https://www.betixpro.com
FRONTEND_URL=https://betixpro.com,https://www.betixpro.com
CORS_ORIGINS=https://betixpro.com,https://www.betixpro.com,http://localhost:5173,http://localhost:3000
BETTER_AUTH_URL=https://server.betixpro.com
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Database
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# JWT and session secrets
ACCESS_TOKEN_SECRET=replace-with-a-long-random-secret
REFRESH_TOKEN_SECRET=replace-with-a-different-long-random-secret
RESET_TOKEN_SECRET=replace-with-another-long-random-secret
REFRESH_COOKIE_SAMESITE=none
REFRESH_COOKIE_SECURE=true

# Admin and support settings
ADMIN_EMAIL=webhost364@gmail.com
ADMIN_PHONE=0700598317
ADMIN_PASSWORD=replace-with-a-strong-admin-password
FROM_EMAIL=noreply@betixpro.com

# Email delivery
SENDGRID_API_KEY=replace-with-sendgrid-api-key
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=noreply@betixpro.com
EMAIL_PASS=replace-with-email-app-password

# Sports and betting integrations
API_SPORTS_KEY=replace-with-sports-api-key
ODDS_API_KEY=replace-with-odds-api-key

# Paystack
PAYSTACK_SECRET_KEY=replace-with-paystack-secret-key
PAYSTACK_PUBLIC_KEY=replace-with-paystack-public-key
PAYSTACK_WEBHOOK_SECRET=replace-with-paystack-webhook-secret
PAYSTACK_CALLBACK_URL=https://server.betixpro.com/api/payments/paystack/callback

# M-Pesa
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=replace-with-mpesa-consumer-key
MPESA_CONSUMER_SECRET=replace-with-mpesa-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=replace-with-mpesa-passkey
MPESA_CALLBACK_URL=https://server.betixpro.com/api/payments/mpesa/callback

# Redis
UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-with-upstash-rest-token
